<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HSK 1 Vocabulary Practice</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Outfit:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #f7f5f0;
    --card: #ffffff;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --hint: #aaa;
    --green: #1D9E75;
    --green-light: #e1f5ee;
    --red: #c0392b;
    --red-light: #fdecea;
    --border: #e5e2db;
    --accent: #2d3a8c;
    --radius: 16px;
    --radius-sm: 10px;
  }
  body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 1rem;
  }
  .app { max-width: 480px; margin: 0 auto; padding-bottom: 3rem; }
  header { text-align: center; padding: 1.5rem 0 1rem; }
  header h1 { font-size: 26px; font-weight: 600; color: var(--accent); letter-spacing: -0.5px; }
  header p { font-size: 14px; color: var(--muted); margin-top: 4px; }
  .mode-tabs { display: flex; gap: 6px; background: var(--card); border-radius: var(--radius-sm); padding: 5px; margin-bottom: 1rem; border: 1px solid var(--border); }
  .tab { flex: 1; padding: 9px; border-radius: 7px; border: none; background: transparent; cursor: pointer; font-size: 14px; font-family: 'Outfit', sans-serif; font-weight: 500; color: var(--muted); transition: all 0.15s; }
  .tab.active { background: var(--accent); color: #fff; }
  .filter-wrap { overflow-x: auto; padding-bottom: 6px; margin-bottom: 1rem; -webkit-overflow-scrolling: touch; }
  .filter-row { display: flex; gap: 6px; width: max-content; }
  .filter-btn { padding: 6px 14px; border-radius: 99px; border: 1px solid var(--border); font-size: 13px; cursor: pointer; background: var(--card); color: var(--muted); font-family: 'Outfit', sans-serif; white-space: nowrap; transition: all 0.15s; }
  .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
  .stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin-bottom: 1rem; }
  .stat { background: var(--card); border-radius: var(--radius-sm); padding: 10px 6px; text-align: center; border: 1px solid var(--border); }
  .stat-num { font-size: 20px; font-weight: 600; }
  .stat-label { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .progress-bar { height: 5px; background: var(--border); border-radius: 3px; margin-bottom: 1.25rem; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.4s ease; }
  .card-wrap { perspective: 1200px; margin-bottom: 1rem; cursor: pointer; user-select: none; -webkit-tap-highlight-color: transparent; }
  .card-inner { position: relative; height: 240px; transform-style: preserve-3d; transition: transform 0.5s cubic-bezier(0.4,0.2,0.2,1); }
  .card-inner.flipped { transform: rotateY(180deg); }
  .card-face { position: absolute; inset: 0; background: var(--card); border-radius: var(--radius); border: 1px solid var(--border); display: flex; flex-direction: column; align-items: center; justify-content: center; backface-visibility: hidden; -webkit-backface-visibility: hidden; padding: 1.5rem; }
  .card-back { transform: rotateY(180deg); }
  .card-hint { font-size: 12px; color: var(--hint); position: absolute; bottom: 16px; }
  .cat-badge { font-size: 11px; color: var(--muted); background: var(--bg); border: 1px solid var(--border); padding: 3px 10px; border-radius: 99px; position: absolute; top: 16px; }
  .chinese { font-family: 'Noto Sans SC', sans-serif; font-size: 64px; font-weight: 700; color: var(--text); line-height: 1; }
  .pinyin { font-size: 22px; color: var(--green); margin-top: 8px; font-weight: 500; }
  .meaning { font-size: 20px; font-weight: 500; color: var(--text); text-align: center; }
  .meaning-small { font-family: 'Noto Sans SC', sans-serif; font-size: 36px; color: var(--muted); margin-top: 10px; }
  .btn-row { display: flex; gap: 10px; margin-bottom: 1rem; }
  .btn { flex: 1; padding: 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--border); font-size: 15px; font-weight: 500; cursor: pointer; font-family: 'Outfit', sans-serif; transition: all 0.15s; background: var(--card); }
  .btn:active { transform: scale(0.97); }
  .btn-wrong { color: var(--red); border-color: #f5b7b1; }
  .btn-wrong:hover { background: var(--red-light); }
  .btn-right { color: var(--green); border-color: #a3e4cc; }
  .btn-right:hover { background: var(--green-light); }
  .btn-next { color: var(--accent); border-color: #c5cae9; }
  .btn-next:hover { background: #eef0fc; }
  .flip-hint { text-align: center; font-size: 13px; color: var(--hint); margin-bottom: 0.5rem; }
  .quiz-q { font-family: 'Noto Sans SC', sans-serif; font-size: 64px; font-weight: 700; text-align: center; margin: 0.5rem 0 0.75rem; color: var(--text); }
  .quiz-pinyin { font-size: 18px; color: var(--green); text-align: center; margin-bottom: 1.25rem; font-weight: 500; min-height: 27px; }
  .quiz-option { width: 100%; padding: 14px 1rem; border-radius: var(--radius-sm); border: 1.5px solid var(--border); font-size: 15px; cursor: pointer; background: var(--card); color: var(--text); text-align: left; margin-bottom: 10px; font-family: 'Outfit', sans-serif; transition: all 0.15s; }
  .quiz-option:hover:not(:disabled) { background: #f0f0f8; border-color: #c5cae9; }
  .quiz-option.correct { border-color: #a3e4cc; background: var(--green-light); color: #0a6644; font-weight: 500; }
  .quiz-option.wrong { border-color: #f5b7b1; background: var(--red-light); color: var(--red); }
  .browse-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
  .browse-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px 10px; text-align: center; }
  .browse-zh { font-family: 'Noto Sans SC', sans-serif; font-size: 34px; font-weight: 700; color: var(--text); line-height: 1.2; }
  .browse-py { font-size: 13px; color: var(--green); margin: 4px 0 2px; font-weight: 500; }
  .browse-en { font-size: 12px; color: var(--muted); }
  .done { text-align: center; padding: 2.5rem 1rem; }
  .done-pct { font-size: 48px; font-weight: 600; color: var(--accent); }
  .done-msg { font-size: 22px; font-weight: 500; margin: 8px 0 0.5rem; }
  .done-sub { font-size: 15px; color: var(--muted); margin-bottom: 1.5rem; }
  .btn-reset { display: inline-block; padding: 12px 28px; background: var(--accent); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 15px; font-weight: 500; cursor: pointer; font-family: 'Outfit', sans-serif; }
</style>
</head>
<body>
<div class="app">
  <header>
    <h1>HSK 1 词汇 Practice</h1>
    <p>150 essential vocabulary words</p>
  </header>
  <div class="mode-tabs">
    <button class="tab active" onclick="setMode('flashcard')" id="tab-flashcard">Flashcards</button>
    <button class="tab" onclick="setMode('quiz')" id="tab-quiz">Quiz</button>
    <button class="tab" onclick="setMode('browse')" id="tab-browse">Browse</button>
  </div>
  <div class="filter-wrap"><div class="filter-row" id="filter-row"></div></div>
  <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
  <div class="stats">
    <div class="stat"><div class="stat-num" id="stat-seen">0</div><div class="stat-label">seen</div></div>
    <div class="stat"><div class="stat-num" id="stat-correct" style="color:#1D9E75">0</div><div class="stat-label">correct</div></div>
    <div class="stat"><div class="stat-num" id="stat-wrong" style="color:#c0392b">0</div><div class="stat-label">missed</div></div>
    <div class="stat"><div class="stat-num" id="stat-left">0</div><div class="stat-label">left</div></div>
  </div>
  <div id="main-area"></div>
</div>
