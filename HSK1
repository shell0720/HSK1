const cats = [...new Set(vocab.map(v=>v.cat))].sort();
let mode = 'flashcard', activeFilter = 'all';
let deck = [], idx = 0, flipped = false;
let correct = 0, wrong = 0, seen = 0;
let quizAnswered = false, quizOptions = [], quizCorrectIdx = 0;

function getDeck() {
  let d = activeFilter==='all' ? [...vocab] : vocab.filter(v=>v.cat===activeFilter);
  return shuffle(d);
}
function shuffle(arr) {
  let a=[...arr];
  for(let i=a.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
  return a;
}
function resetSession() {
  deck=getDeck(); idx=0; flipped=false; correct=0; wrong=0; seen=0; quizAnswered=false;
  updateStats(); render();
}
function setMode(m) {
  mode=m;
  document.querySelectorAll('.tab[id^=tab]').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+m).classList.add('active');
  resetSession();
}
function setFilter(f) {
  activeFilter=f;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  document.querySelector('.filter-btn[data-cat="'+f+'"]').classList.add('active');
  resetSession();
}
function buildFilterRow() {
  const row=document.getElementById('filter-row');
  let html=`<button class="filter-btn active" data-cat="all" onclick="setFilter('all')">All (${vocab.length})</button>`;
  cats.forEach(c=>{
    const cnt=vocab.filter(v=>v.cat===c).length;
    html+=`<button class="filter-btn" data-cat="${c}" onclick="setFilter('${c}')">${c} (${cnt})</button>`;
  });
  row.innerHTML=html;
}
function updateStats() {
  const total=deck.length, left=Math.max(0,total-idx);
  document.getElementById('stat-seen').textContent=seen;
  document.getElementById('stat-correct').textContent=correct;
  document.getElementById('stat-wrong').textContent=wrong;
  document.getElementById('stat-left').textContent=left;
  const pct=total>0?Math.round((idx/total)*100):0;
  document.getElementById('progress-fill').style.width=pct+'%';
}
function render() {
  if(mode==='flashcard') renderFlashcard();
  else if(mode==='quiz') renderQuiz();
  else renderBrowse();
}
function renderFlashcard() {
  const el=document.getElementById('main-area');
  if(idx>=deck.length){el.innerHTML=doneHTML();return;}
  const w=deck[idx];
  el.innerHTML=`
    <div class="card-wrap" onclick="flipCard()">
      <div class="card-inner" id="card-inner">
        <div class="card-face">
          <span class="cat-badge">${w.cat}</span>
          <div class="chinese">${w.zh}</div>
          <div class="card-hint">tap to reveal</div>
        </div>
        <div class="card-face card-back">
          <div class="pinyin">${w.py}</div>
          <div class="meaning">${w.en}</div>
          <div class="meaning-small">${w.zh}</div>
          <div class="card-hint">tap to flip back</div>
        </div>
      </div>
    </div>
    <p class="flip-hint" id="flip-hint">Flip the card, then mark yourself</p>
    <div class="btn-row" id="answer-btns" style="display:none">
      <button class="btn btn-wrong" onclick="markWrong()">✗ Missed it</button>
      <button class="btn btn-right" onclick="markRight()">✓ Got it</button>
    </div>`;
}
function flipCard() {
  flipped=!flipped;
  document.getElementById('card-inner').classList.toggle('flipped',flipped);
  document.getElementById('answer-btns').style.display=flipped?'flex':'none';
  document.getElementById('flip-hint').style.display=flipped?'none':'block';
}
function markRight(){correct++;seen++;idx++;flipped=false;updateStats();render();}
function markWrong(){wrong++;seen++;idx++;flipped=false;updateStats();render();}

function renderQuiz() {
  const el=document.getElementById('main-area');
  if(idx>=deck.length){el.innerHTML=doneHTML();return;}
  const w=deck[idx];
  if(!quizAnswered){
    let pool=vocab.filter(v=>v.zh!==w.zh);
    quizOptions=shuffle([w,...shuffle(pool).slice(0,3)]);
    quizCorrectIdx=quizOptions.indexOf(w);
  }
  const optHTML=quizOptions.map((o,i)=>{
    let cls='quiz-option';
    if(quizAnswered&&i===quizCorrectIdx)cls+=' correct';
    return `<button class="${cls}" ${quizAnswered?'disabled':''} onclick="answerQuiz(${i})">${o.en}</button>`;
  }).join('');
  el.innerHTML=`
    <p style="text-align:center;font-size:13px;color:var(--muted);margin-bottom:4px;">What does this mean?</p>
    <div class="quiz-q">${w.zh}</div>
    <div class="quiz-pinyin">${quizAnswered?w.py:'&nbsp;'}</div>
    ${optHTML}
    ${quizAnswered?`<div style="text-align:center;margin-top:0.5rem;"><button class="btn btn-next" onclick="nextQuiz()">Next →</button></div>`:''}`;
}
function answerQuiz(i) {
  if(quizAnswered)return;
  quizAnswered=true; seen++;
  if(i===quizCorrectIdx)correct++;else wrong++;
  updateStats(); renderQuiz();
}
function nextQuiz(){idx++;quizAnswered=false;updateStats();render();}

function renderBrowse() {
  const el=document.getElementById('main-area');
  const filtered=activeFilter==='all'?vocab:vocab.filter(v=>v.cat===activeFilter);
  let html='<div class="browse-grid">';
  filtered.forEach(w=>{
    html+=`<div class="browse-card">
      <div class="browse-zh">${w.zh}</div>
      <div class="browse-py">${w.py}</div>
      <div class="browse-en">${w.en}</div>
    </div>`;
  });
  html+='</div>';
  el.innerHTML=html;
  document.getElementById('stat-seen').textContent=filtered.length;
  document.getElementById('stat-correct').textContent='—';
  document.getElementById('stat-wrong').textContent='—';
  document.getElementById('stat-left').textContent='—';
  document.getElementById('progress-fill').style.width='100%';
}
function doneHTML() {
  const total=deck.length, pct=total>0?Math.round((correct/total)*100):0;
  const msg=pct>=80?'太棒了！Excellent!':pct>=60?'不错！Good job!':'继续加油！Keep going!';
  return `<div class="done">
    <div style="font-size:52px;margin-bottom:0.75rem;">${pct>=80?'🎉':pct>=60?'👍':'💪'}</div>
    <div class="done-pct">${pct}%</div>
    <div class="done-msg">${msg}</div>
    <div class="done-sub">${correct} correct out of ${total} words</div>
    <button class="btn-reset" onclick="resetSession()">Practice again</button>
  </div>`;
}
buildFilterRow();
resetSession();
</script>
</body>
</html>
